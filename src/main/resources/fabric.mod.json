{
	"schemaVersion": 1,
	"id": "medved",
	"version": "${mod_version}",
	"name": "Medved",
	"description": "A Fabric utility mod for PvP, minigames, and more.",
	"authors": [
		"ghluka"
	],
	"custom": {
		"firmament:hide_from_modlist": true
	},
	"contact": {
		"homepage": "https://luka.onl/medved/",
		"sources": "https://github.com/ghluka/MedvedClient"
	},
	"license": "GPL-3.0-with-linking-exception",
	"icon": "assets/medved/icon.png",
	"environment": "*",
	"entrypoints": {
		"client": [
			{
				"value": "me.ghluka.medved.MedvedClient",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"medved.mixins.json",
		{
			"config": "medved.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=${loader_version}",
		"minecraft": "~${minecraft_version}",
		"java": ">=25",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}